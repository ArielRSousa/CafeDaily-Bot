# Discord — criar em https://discord.com/developers/applications
DISCORD_TOKEN=

# Opcional: ID do servidor para registrar slash commands mais rápido (recomendado em dev)
DISCORD_GUILD_ID=

# Canal onde as Dailys registradas serão enviadas (só staff/admins devem ver)
DAILY_ADMIN_CHANNEL_ID=

# MongoDB — no Docker Compose use o host "mongo"
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB_NAME=cafedaily

# Fuso para exibir data/hora no relatório (IANA)
TIMEZONE=America/Sao_Paulo
